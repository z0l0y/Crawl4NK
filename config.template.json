{
    "cookie": "请在此处填入你登录牛客网后的 Cookie 字符串",
    "keywords": ["后端 面经"],
    "max_pages": 5,
    "max_items_per_keyword": 10,
    "output_file": "nowcoder_data",
    "output_formats": ["xlsx", "md", "txt"],
    "show_progress_bar": true,
    "crawl_debug_log": false,
    "company_debug_log": false,
    "request_connect_timeout": 5,
    "request_read_timeout": 15,
    "request_retry_count": 2,
    "request_retry_backoff": 0.5,
    "filtered_posts_log": false,
    "filtered_posts_log_limit": 50,
    "include_id_column": false,
    "drop_unknown_company_posts": true,
    "debug_log": false,
    "filter_rules": {
        "must_contain": ["面经", "后端", "面", "实习", "日常", "开发", "研发"],
        "must_not_contain": ["内推", "引流", "简历", "答疑"]
    }
}